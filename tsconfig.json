{
    "compilerOptions": {
        "rootDir": "./",
        "outDir": "./dist",
        "module": "nodenext",
        "target": "es2020",
        "sourceMap": true,
        "declaration": true,
        "declarationMap": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "strict": true,
        "jsx": "react-jsx",
        "isolatedModules": true,
        "noUncheckedSideEffectImports": true,
        "moduleDetection": "force",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "nodenext",
        "noEmitOnError": true,
        "noImplicitReturns": true
    },
    "include": [
        "src/**/*",
        "eslint.config.mts",
        "vitest.config.ts"
    ]
}