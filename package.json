{
    "name": "ml-segmentation-2",
    "version": "2.0.0-alpha.4",
    "description": "This side project builds on my previous work in machine learning-based image segmentation. The current focus is on enhancing software quality and user experience. It serves as a practical environment to improve and deepen my software engineering skills.",
    "homepage": "https://github.com/kerimyalcin95/ml-segmentation-2#readme",
    "bugs": {
        "url": "https://github.com/kerimyalcin95/ml-segmentation-2/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kerimyalcin95/ml-segmentation-2.git"
    },
    "license": "MIT",
    "author": "Kerim Yalcin",
    "type": "module",
    "main": "dist/src/main.js",
    "scripts": {
        "build": "npm run clean && tsc && npm --prefix ./svelte-frontend run build",
        "start": "npm run build && electron .",
        "make": "npm run build && electron-builder",
        "test": "vitest",
        "clean": "rimraf dist",
        "package": "electron-builder --dir",
        "make-package": "npm run build && electron-builder --dir",
        "make-standalone": "npm run make-package",
        "make-setup": "npm run build && electron-builder",
        "make-installer": "npm run make-setup",
        "fe-build": "npm --prefix ./svelte-frontend run build",
        "fe-preview": "npm --prefix ./svelte-frontend run preview",
        "fe-start": "npm run fe-preview",
        "fe-dev": "npm --prefix ./svelte-frontend run dev",
        "fe-check": "npm --prefix ./svelte-frontend run check",
        "fe-test": "npm --prefix ./svelte-frontend run test",
        "fe-npm": "npm --prefix ./svelte-frontend"
    },
    "dependencies": {
        "debug": "^4.4.3",
        "env-paths": "^3.0.0",
        "graceful-fs": "^4.2.11",
        "ms": "^2.1.3",
        "progress": "^2.0.3",
        "semver": "^7.8.5",
        "sumchecker": "^3.0.1",
        "undici": "^7.28.0",
        "undici-types": "^7.18.2",
        "ws": "^8.21.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@eslint/json": "^2.0.1",
        "@types/electron-squirrel-startup": "^1.0.2",
        "@types/node": "^26.1.1",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/parser": "^8.64.0",
        "electron": "^43.1.1",
        "electron-builder": "^26.15.3",
        "eslint": "^10.7.0",
        "eslint-plugin-svelte": "^3.20.0",
        "globals": "^17.7.0",
        "jiti": "^2.7.0",
        "rimraf": "^6.1.3",
        "svelte-eslint-parser": "^1.8.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.64.0",
        "vitest": "^4.1.10"
    },
    "allowScripts": {
        "electron-winstaller@5.4.4": true
    },
    "build": {
        "appId": "com.kerimyalcin.mlsegmentation2",
        "productName": "ML-Segmentation",
        "directories": {
            "output": "make"
        },
        "asar": true,
        "asarUnpack": [
            "**/*.py"
        ],
        "icon": "assets/icon.ico",
        "files": [
            "dist/src/**/*",
            "svelte-frontend/dist/**/*",
            "python/**/*"
        ],
        "win": {
            "icon": "assets/icon.ico",
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "artifactName": "${productName}-${version}-${arch}.exe"
        },
        "nsis": {
            "installerIcon": "assets/icon.ico",
            "uninstallerIcon": "assets/icon.ico",
            "perMachine": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "ML-Segmentation",
            "allowToChangeInstallationDirectory": true,
            "oneClick": false
        },
        "linux": {
            "icon": "assets/icons",
            "target": [
                {
                    "target": "deb",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "category": "Science",
            "artifactName": "${productName}-${version}-${arch}.deb"
        },
        "mac": {
            "icon": "assets/icon.icns",
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "x64",
                        "arm64"
                    ]
                }
            ],
            "artifactName": "${productName}-${version}-${arch}.dmg"
        }
    }
}